#!/usr/bin/env bash
# AutoSec pre-commit hook: block commits that contain likely secrets or accidental
# private files. Add patterns over time; do not relax existing ones.
set -euo pipefail

# Files staged in this commit (Added, Copied, Modified)
mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACM)

# Patterns to flat-out reject by filename — these should never be committed.
FORBIDDEN_PATHS=(
  '\.env$'
  '\.env\..*'           # but allow .env.example
  '.*\.pem$'
  '.*\.key$'
  '.*\.p12$'
  '.*\.pfx$'
  '^\.npmrc$'
  '^\.aws/'
  '.*id_rsa$'
  '.*id_ed25519$'
  '.*credentials\.json$'
)

fail=0
for f in "${STAGED[@]}"; do
  base="$(basename "$f")"
  if [ "$base" = ".env.example" ]; then continue; fi
  for pat in "${FORBIDDEN_PATHS[@]}"; do
    if [[ "$f" =~ $pat ]]; then
      echo "[pre-commit] BLOCKED: '$f' matches forbidden path pattern '$pat'" >&2
      fail=1
    fi
  done
done

# Content patterns — high-confidence secret shapes only, to keep noise low.
SECRET_PATTERNS=(
  'ghp_[A-Za-z0-9]{30,}'                 # GitHub personal access token (classic)
  'gho_[A-Za-z0-9]{30,}'                 # GitHub OAuth token
  'ghs_[A-Za-z0-9]{30,}'                 # GitHub server token
  'github_pat_[A-Za-z0-9_]{60,}'         # GitHub fine-grained PAT
  'sk-ant-[A-Za-z0-9_-]{80,}'            # Anthropic key
  'sk-[A-Za-z0-9]{40,}'                  # OpenAI-style key
  'AKIA[0-9A-Z]{16}'                     # AWS access key id
  'ASIA[0-9A-Z]{16}'                     # AWS temp access key id
  'AIza[0-9A-Za-z_-]{30,}'               # Google API key
  'xox[baprs]-[A-Za-z0-9-]{10,}'         # Slack token
  '-----BEGIN [A-Z ]*PRIVATE KEY-----'   # PEM-encoded private key
)

for f in "${STAGED[@]}"; do
  [ -f "$f" ] || continue
  # Skip binary files and the lockfile (large, no secrets)
  case "$f" in
    package-lock.json|*.lock|*.png|*.jpg|*.jpeg|*.gif|*.pdf|*.zip|*.tar|*.tgz) continue ;;
  esac
  for pat in "${SECRET_PATTERNS[@]}"; do
    if grep -EnH --binary-files=without-match "$pat" "$f" 2>/dev/null; then
      echo "[pre-commit] BLOCKED: '$f' contains a value matching secret pattern: $pat" >&2
      fail=1
    fi
  done
done

if [ "$fail" -ne 0 ]; then
  cat >&2 <<'EOF'

[pre-commit] Commit blocked by AutoSec hook.
  - To override for a single legitimate commit: git commit --no-verify
    (only do this when you have manually verified the flagged content is safe)
  - To add a new pattern, edit .githooks/pre-commit and commit it.
EOF
  exit 1
fi

exit 0
